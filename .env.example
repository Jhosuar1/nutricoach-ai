# Cadena de conexión de tu proyecto Neon (Postgres)
# La copias desde el dashboard de Neon: https://console.neon.tech
# Ejemplo: postgresql://usuario:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Clave secreta para firmar las sesiones de login. Invéntate cualquier texto largo y aleatorio,
# por ejemplo generándolo con: openssl rand -hex 32
SESSION_SECRET=

# Tu API key GRATIS de Google Gemini (https://aistudio.google.com/apikey)
# No pide tarjeta de crédito. Nunca la pongas en el código del cliente: aquí queda solo en el servidor.
GEMINI_API_KEY=
